<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.xuanchen.generator.gendatabase.mapper.GenDatabaseMapper">
    <!-- 回收站 列表 -->
    <select id="listRecycleBin" resultType="com.xuanchen.generator.gendatabase.entity.GenDatabase">
        SELECT
        id
        ,conn_type
        ,conn_name
        ,host
        ,port
        ,db_name
        ,user_name
        ,password
        ,order_no
        ,status
        ,del_flag
        ,create_by
        ,create_time
        ,update_by
        ,update_time
        FROM
        gen_db_conn
        WHERE
        del_flag = 1
    </select>
    <!-- 回收站 彻底删除 -->
    <delete id="deleteRecycleBin">
        DELETE FROM gen_db_conn
        WHERE
        del_flag = 1
        AND id in
        <foreach collection="genDatabaseIds" index="index" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
    <!-- 回收站 还原 -->
    <update id="revertRecycleBin">
        UPDATE gen_db_conn set del_flag = 0
        WHERE
        del_flag = 1
        AND id in
        <foreach collection="genDatabaseIds" index="index" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </update>
</mapper>